	quest.4C573C0A6C4DD09F.quest_subtitle: "适用于装备，在空中时提升攻防"
	quest.4C573C0A6C4DD09F.title: "龙裔强化"
	quest.4C8244CB69CED560.title: "要塞"
	quest.4C83E1A30593ACEB.quest_desc: [
		"大大提升你的触及距离和击退能力"
		"同时使用2个机械手可以让你的手超级长"
		"这个东西容易损坏，建议量产，或者使用附魔"
		"&7但如果有现实第二诅咒的话会失效"
	]
	quest.4D41F00C7C067FC9.quest_subtitle: "不要在家里使用！"
	quest.4D4B8C2848C991A6.quest_desc: [
