		""
		"移除了创造马达的配方"
	]
	quest.24CA1EFD51F9BF39.quest_subtitle: "这是一次很&cSM&r的更新"
	quest.24E8A6F9C1801B64.quest_desc: [
		"船体可能因为爆炸和怪物的攻击受损，尤其要注意&e船底的气球"
