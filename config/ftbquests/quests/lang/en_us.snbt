	]
	quest.1ACDC81FD4A5C06E.title: "将药水制作成药水护符"
	quest.1ADF7D3D6D5E7C53.quest_desc: [
		"&c重伤&r：每级-40%治疗效果"
		""
		"&c流血&r：每2s造成&e无视护甲的伤害"
		""
		"&c破甲&r：每级受伤增加20%"
		""
		"&a活力迸发&r：每级+20%治疗效果"
		""
