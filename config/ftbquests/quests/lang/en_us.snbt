	quest.2431BCAE245E4C47.quest_desc: ["使用青花制作的谜之炖菜可以提供短时间的幸运"]
	quest.24CA1EFD51F9BF39.quest_desc: [
		"mod的修改："
		"新增&6all the modium、&e意志坚定、&3口渴&r等"
		"新增&3TaCZ Tweaks&7(使子弹无法穿过物理结构)"
